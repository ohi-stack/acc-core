{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://onegodian.org/schemas/authority-policy.schema.json",
  "title": "ACC Authority Policy",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version","policy_id","resource","action","effect","roles","environment"],
  "properties": {
    "schema_version": {"type":"string","const":"1.0.0"},
    "policy_id": {"type":"string"},
    "resource": {"type":"string"},
    "action": {"type":"string"},
    "effect": {"type":"string","enum":["allow","deny","approval_required"]},
    "roles": {"type":"array","minItems":1,"items":{"type":"string"}},
    "environment": {"type":"array","minItems":1,"items":{"type":"string","enum":["dev","staging","production"]}},
    "scope": {"type":"object"},
    "risk_level": {"type":"string","enum":["low","medium","high","critical"],"default":"low"},
    "requires_reason": {"type":"boolean","default":false},
    "enabled": {"type":"boolean","default":true},
    "created_at": {"type":"string","format":"date-time"}
  }
}
